VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# GitHub Releases (pour uploader les APKs > 50 Mo, gratuit jusqu'à 2 Go)
# Crée un token sur https://github.com/settings/tokens/new
# Scope requis : "public_repo" (si repo public) ou "repo" (si repo privé)
VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
VITE_GITHUB_OWNER=ton-username-github
VITE_GITHUB_REPO=flutter_chat_kit
